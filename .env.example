# Database Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api
DATABASE_URL=postgresql://user:password@localhost:5432/budgeting_app

# Authentication
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Paystack Payment Processing
# Get keys from: https://dashboard.paystack.com
# For testing, use test keys (they start with pk_test_ and sk_test_)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_DEDICATED_ACCOUNT_BANK=wema-bank

# Statement Email Delivery
# Recommended provider: Resend (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@rilstack.xyz

# NIN Validation APIs
# Choose one or more for real NIN verification

# Option 1: Dojah API (Recommended - Free tier available)
# Get keys from: https://dojah.io/dashboard
# Free tier includes 100 KYC requests per month
DOJAH_API_KEY=your_dojah_api_key_here
NEXT_PUBLIC_DOJAH_APP_ID=your_dojah_app_id_here
NEXT_PUBLIC_DOJAH_PUBLIC_KEY=your_dojah_public_key_here

# Option 2: Identitypass API (Paid option)
# Get keys from: https://identitypass.com
IDENTITYPASS_API_KEY=your_identitypass_api_key_here

# Option 3: Interswitch API (OAuth-based)
# Get credentials from: https://interswitchng.com
# Requires Client ID and Secret for OAuth2 client_credentials flow
# Test endpoint: https://qa.interswitchng.com/passport/oauth/token
# Verification endpoint: https://qa.interswitchng.com/passport/api/v2/kyc/nin/verify
INTERSWITCH_CLIENT_ID=your_interswitch_client_id_here
INTERSWITCH_CLIENT_SECRET=your_interswitch_client_secret_here

# Application
NEXT_PUBLIC_APP_NAME=RILSTACK
NEXT_PUBLIC_APP_URL=https://rilstack.com

# SeaTable (Required for auth + user storage)
SEATABLE_API_TOKEN=your_seatable_api_token
SEATABLE_SERVER=https://cloud.seatable.io
SEATABLE_WORKSPACE_ID=your_workspace_id
SEATABLE_BASE_NAME=your_base_name

# Third-party APIs (Optional)
# ALPHA_VANTAGE_API_KEY=your-api-key
# FINNHUB_API_KEY=your-api-key
# OPay Digital Wallet (Alternative payment method)
# Get credentials from: https://merchant.opayweb.com
OPAY_MERCHANT_ID=your_opay_merchant_id_here
OPAY_API_KEY=your_opay_api_key_here